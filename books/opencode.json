{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["../agent.md"],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "llava": {
          "name": "Llava 7B (local)"
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "playwright-mcp"],
      "cwd": "..",
      "enabled": true
    }
  }
}
